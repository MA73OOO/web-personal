    {
      "mode": "managed",
      "type": "aws_cloudfront_function",
      "name": "url_rewrite",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::794528240889:function/ma73o-hub-url-rewrite",
            "code": "async function handler(event) {\n  var request = event.request;\n  var uri = request.uri;\n\n  // Si no tiene extensión y no termina en /, agregar .html\n  if (!uri.includes('.') \u0026\u0026 !uri.endsWith('/')) {\n    request.uri = uri + '.html';\n  } else if (uri.endsWith('/')) {\n    request.uri = uri + 'index.html';\n  }\n\n  return request;\n}\n",
            "comment": "Reescribe rutas limpias de Next.js a archivos .html en S3",
            "etag": "ETVPDKIKX0DER",
            "id": "ma73o-hub-url-rewrite",
            "key_value_store_associations": [],
            "live_stage_etag": "ETVPDKIKX0DER",
            "name": "ma73o-hub-url-rewrite",
            "publish": true,
            "runtime": "cloudfront-js-2.0",
            "status": "DEPLOYED"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
